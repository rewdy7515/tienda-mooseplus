{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "src/frontend/(.*)", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/", "dest": "/src/frontend/pages/index.html" },
    { "src": "/(.*)", "dest": "/src/frontend/pages/$1" }
  ]
}
