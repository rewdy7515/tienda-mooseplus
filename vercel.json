{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "src/frontend/pages/**", "use": "@vercel/static" },
    { "src": "src/frontend/styles/**", "use": "@vercel/static" },
    { "src": "src/frontend/scripts/**", "use": "@vercel/static" },
    { "src": "src/frontend/components/**", "use": "@vercel/static" },
    { "src": "src/frontend/public/**", "use": "@vercel/static" },
    { "src": "src/frontend/partials/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
