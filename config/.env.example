PORT=3000
NODE_ENV=production

SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=TU_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=TU_SUPABASE_SERVICE_ROLE_KEY

PUBLIC_SITE_URL=https://mooseplus.com
SITE_URL=https://mooseplus.com
CORS_ORIGINS=https://mooseplus.com,https://www.mooseplus.com

BDV_WEBHOOK_TOKEN=CAMBIA_ESTE_TOKEN
GMAIL_OAUTH_CLIENT_ID=TU_GOOGLE_OAUTH_CLIENT_ID
GMAIL_OAUTH_CLIENT_SECRET=TU_GOOGLE_OAUTH_CLIENT_SECRET
# Debe coincidir exactamente con Authorized redirect URI en Google Cloud.
GMAIL_OAUTH_REDIRECT_URI=https://api.mooseplus.com/api/admin/binance-gmail/oauth/callback
# Se llena luego del callback OAuth (refresh token).
GMAIL_OAUTH_REFRESH_TOKEN=
# Scope recomendado para lectura de correos.
GMAIL_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly

# Sincronización de correos Binance vía Gmail API
BINANCE_GMAIL_SYNC_ENABLED=false
BINANCE_GMAIL_SYNC_INTERVAL_MS=45000
BINANCE_GMAIL_MAX_RESULTS=20
BINANCE_GMAIL_LOOKBACK_MINUTES=240
BINANCE_GMAIL_ORDER_WINDOW_MS=10800000
BINANCE_GMAIL_AMOUNT_TOLERANCE=0.01
# Opcional: restringir labels (ej: INBOX)
# BINANCE_GMAIL_LABEL_IDS=INBOX
BINANCE_GMAIL_QUERY=from:(binance.com) ("received" OR "recibido" OR "payment" OR "pago" OR "paid")
# Opcional: IDs explícitos del método Binance separados por coma.
# BINANCE_METODO_PAGO_IDS=5

# Monto único Binance (XX.XX1, XX.XX2...)
BINANCE_UNIQUE_AMOUNT_ENABLED=true
BINANCE_UNIQUE_AMOUNT_MAX_DECIMAL_STEP=9
# 1 = siempre aplica XX.XX1 por defecto. 2 = solo cuando haya >=2 pendientes activas.
BINANCE_UNIQUE_AMOUNT_MIN_PENDING=1

SESSION_COOKIE_SECRET=CAMBIA_ESTE_SECRETO
SIGNUP_TOKEN_SECRET=CAMBIA_ESTE_SECRETO
SIGNUP_TOKEN_TTL_SEC=86400

ENABLE_WHATSAPP=false
# Opcional: fija una ruta persistente si no quieres usar .wwebjs_auth/.wwebjs_cache del proyecto.
# WHATSAPP_RUNTIME_DIR=/var/www/tienda-mooseplus-main/.mooseplus-runtime/whatsapp
# Opcional: fija el cache de Chrome/Puppeteer si tu entorno hereda un HOME inválido.
# WHATSAPP_BROWSER_CACHE_DIR=/var/www/tienda-mooseplus-main/.puppeteer-cache
# Opcional: grupo para alertas de reportes. Prioriza el ID del chat.
# WHATSAPP_REPORTES_GROUP_CHAT_ID=120363xxxxxxxxxxxx@g.us
# WHATSAPP_REPORTES_GROUP_NAME=Reportes moose+
# Los reportes se envían solo al grupo configurado.
# Worker automático: detecta nuevas filas en reportes y envía WhatsApp.
WHATSAPP_REPORTES_WATCHER=true
WHATSAPP_REPORTES_WATCHER_INTERVAL_MS=15000
WHATSAPP_REPORTES_WATCHER_BATCH=80
# Opcional: usa Chrome del sistema si ya lo tienes instalado.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
# Opcional: desactiva la descarga automatica de Chrome si quieres manejarla manualmente.
# WHATSAPP_AUTO_INSTALL_BROWSER=true
WHATSAPP_AUTO_RECORDATORIOS=true
NUEVO_SERVICIO_NOTIF_QUEUE=true
NUEVO_SERVICIO_NOTIF_QUEUE_INTERVAL_MS=15000
NUEVO_SERVICIO_NOTIF_QUEUE_BATCH=20

# Auto-entrega de ventas pendientes gift card al detectar nuevas inserciones en tarjetas_de_regalo
AUTO_GIFTCARD_PENDING_DELIVERY=true
AUTO_GIFTCARD_PENDING_DELIVERY_INTERVAL_MS=15000
AUTO_GIFTCARD_PENDING_DELIVERY_BATCH=120
